# =============================================================
# AskDB-Go Environment Variables — EXAMPLE FILE
#
# Copy this file to .env and fill in values for local development.
# .env is git-ignored and must NEVER be committed.
#
# WARNING: These are example values for local development only.
#          DO NOT use these values in any shared or production environment.
#          In production, inject variables through the process environment
#          or a secrets manager — never via .env files.
# =============================================================

# API server port
API_PORT=8080

# MySQL DSN — connects to askdb_app with the restricted askdb_app user.
# Format: user:password@tcp(host:port)/dbname?params
# WARNING: The root account is not used here; root is for container init only.
MYSQL_DSN=askdb_app:app_dev_pass@tcp(localhost:3306)/askdb_app?parseTime=true&charset=utf8mb4

# MySQL reader DSN — connects to askdb_demo with the SELECT-only askdb_reader user.
# Used by the read-only QueryExecutor (database/sql), isolated from the GORM pool.
# WARNING: dev-only password; askdb_reader has SELECT privileges on askdb_demo only.
MYSQL_READER_DSN=askdb_reader:reader_dev_pass@tcp(localhost:3306)/askdb_demo?parseTime=true&charset=utf8mb4

# Maximum duration for a single demo-database read query (Go duration string).
QUERY_TIMEOUT=5s

# Redis
REDIS_ADDR=localhost:6379
# REDIS_PASS=  # leave empty for local dev (no auth configured)

# Query result cache TTL (Go duration string, e.g. 15m, 1h).
# Must be greater than zero. Results are stored in Redis under a short-lived key;
# after this period the result is unavailable and must be re-submitted.
# WARNING: This is a dev-only default. Tune for your production SLA.
QUERY_RESULT_TTL=15m

# SQL Guard — resource limits.
# MAX_QUERY_ROWS: maximum rows the SQL Guard allows via LIMIT (and the executor
# hard cap). Must be a positive integer.
MAX_QUERY_ROWS=100

# MAX_RESULT_BYTES: maximum size in bytes of the JSON payload written to Redis.
# A result exceeding this limit is rejected with RESULT_TOO_LARGE. Must be a
# positive integer.
MAX_RESULT_BYTES=1048576

# RabbitMQ AMQP URL
# WARNING: guest/guest is the Docker dev default. Change before any shared deployment.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
