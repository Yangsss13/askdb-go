# =============================================================
# AskDB-Go Environment Variables — EXAMPLE FILE
#
# Copy this file to .env and fill in values for local development.
# .env is git-ignored and must NEVER be committed.
#
# WARNING: These are example values for local development only.
#          DO NOT use these values in any shared or production environment.
#          In production, inject variables through the process environment
#          or a secrets manager — never via .env files.
# =============================================================

# API server port
API_PORT=8080

# MySQL DSN — connects to askdb_app with the restricted askdb_app user.
# Format: user:password@tcp(host:port)/dbname?params
# WARNING: The root account is not used here; root is for container init only.
MYSQL_DSN=askdb_app:app_dev_pass@tcp(localhost:3306)/askdb_app?parseTime=true&charset=utf8mb4

# MySQL reader DSN — connects to askdb_demo with the SELECT-only askdb_reader user.
# Used by the read-only QueryExecutor (database/sql), isolated from the GORM pool.
# WARNING: dev-only password; askdb_reader has SELECT privileges on askdb_demo only.
MYSQL_READER_DSN=askdb_reader:reader_dev_pass@tcp(localhost:3306)/askdb_demo?parseTime=true&charset=utf8mb4

# Maximum duration for a single demo-database read query (Go duration string).
QUERY_TIMEOUT=5s

# Redis
REDIS_ADDR=localhost:6379
# REDIS_PASS=  # leave empty for local dev (no auth configured)

# Query result cache TTL (Go duration string, e.g. 15m, 1h).
# Must be greater than zero. Results are stored in Redis under a short-lived key;
# after this period the result is unavailable and must be re-submitted.
# WARNING: This is a dev-only default. Tune for your production SLA.
QUERY_RESULT_TTL=15m

# SQL Guard — resource limits.
# MAX_QUERY_ROWS: maximum rows the SQL Guard allows via LIMIT (and the executor
# hard cap). Must be a positive integer.
MAX_QUERY_ROWS=100

# MAX_RESULT_BYTES: maximum size in bytes of the JSON payload written to Redis.
# A result exceeding this limit is rejected with RESULT_TOO_LARGE. Must be a
# positive integer.
MAX_RESULT_BYTES=1048576

# RabbitMQ AMQP URL
# WARNING: guest/guest is the Docker dev default. Change before any shared deployment.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT authentication
# JWT_SECRET: HS256 signing key, must be at least 32 bytes.
# WARNING: Generate a random secret for every deployment — this value is dev-only.
JWT_SECRET=dev-only-secret-change-me-in-prod-32b
JWT_ISSUER=askdb-api
# JWT_ACCESS_TTL=24h  # default; adjust per security policy

# =============================================================
# Phase 6B: Data-source management
# =============================================================

# DATA_SOURCE_KEY: AES-256 master key for password encryption.
# Must be exactly 32 bytes encoded as standard base64.
# Generate: openssl rand -base64 32
# WARNING: This is a dev-only placeholder — generate a real key for any deployment.
# NEVER commit the real key; inject via environment or secrets manager.
DATA_SOURCE_KEY=ZGV2LW9ubHkta2V5LWNoYW5nZS1tZS0zMmJ5dGVzISE=

# ALLOWED_DB_PORTS: comma-separated whitelist of TCP ports for outbound DB connections.
# Default is 3306 (MySQL). Extend only if additional ports are explicitly needed.
ALLOWED_DB_PORTS=3306

# PRIVATE_HOST_ALLOWLIST: comma-separated CIDRs that are allowed even though they
# fall in normally-blocked private/loopback ranges. Leave empty in production.
# For Docker local dev where MySQL runs on the bridge network:
# PRIVATE_HOST_ALLOWLIST=172.17.0.0/16
PRIVATE_HOST_ALLOWLIST=

# DATA_SOURCE_CONNECT_TIMEOUT: default TCP connect timeout for outbound data-source
# connections. Per-source overrides are stored in the data_sources table.
# DATA_SOURCE_CONNECT_TIMEOUT=5s

# =============================================================
# Phase 7: RabbitMQ Retry, DLQ and Consumer Idempotency
# =============================================================

# MQ_CONFIRM_TIMEOUT: maximum time to wait for a Publisher Confirm ACK from the
# broker before treating the publish as failed (Outbox Dispatcher, Retry and
# DLQ publishes). Go duration string.
# WARNING: dev-only default; tune for your broker round-trip latency.
MQ_CONFIRM_TIMEOUT=5s

# RETRY_MAX_ATTEMPTS: number of retries allowed after the first execution failure.
# 0 = no retries (failed jobs go directly to DLQ on the first transient error).
# 3 = up to 3 retries; the 4th failure routes to DLQ and marks the job failed.
# NOTE: This is At-Least-Once delivery — retried messages may be processed more
#       than once. The durable processed_messages table provides message and
#       business-key idempotency, but DLQ messages may be delivered more than once
#       if the DLQ publish succeeds but the MySQL SetFailed write fails before ACK.
#       Transactional Outbox is implemented in Phase 8, but delivery remains
#       At-Least-Once. Exactly Once is not implemented.
RETRY_MAX_ATTEMPTS=3

# RETRY_DELAY: fixed TTL applied to messages on the retry queue (askdb.query.retry).
# When the TTL expires, the message is re-routed via Dead-Letter Exchange back to
# the main askdb.query.execution queue. Go duration string.
RETRY_DELAY=30s

# =============================================================
# Phase 8: Transactional Outbox Dispatcher
# =============================================================

# Dispatcher polling and claim settings.
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=10
OUTBOX_LEASE_TTL=30s

# Database-scheduled, capped exponential backoff for publish failures.
# These retries do not use the RabbitMQ Retry Queue.
OUTBOX_BASE_BACKOFF=5s
OUTBOX_MAX_BACKOFF=10m

# Published outbox rows are retained for this period, then deleted in batches.
OUTBOX_PUBLISHED_RETAIN=24h
OUTBOX_CLEAN_BATCH=100

# Consumer idempotency Lease is not currently configurable by environment:
# internal/queryjob fixes leaseTTL at 30s and renews it every leaseTTL/3 (about 10s).
# An expired Lease can be taken over by another Worker using a lease_token CAS.

# =============================================================
# Phase 9: LLM SQL generation
# =============================================================

# LLM_PROVIDER: selects the SQL-generation backend.
#   "fake"               — deterministic stub, no network calls (default, safe for dev/CI).
#   "openai-compatible"  — real Chat Completions endpoint; requires LLM_BASE_URL and LLM_API_KEY.
LLM_PROVIDER=fake

# LLM_BASE_URL: API root for the openai-compatible provider (e.g. https://api.openai.com/v1).
# Must use HTTPS in production. Omit when LLM_PROVIDER=fake.
# WARNING: Never log this value; it may contain the host of a paid API endpoint.
# LLM_BASE_URL=https://api.openai.com/v1

# LLM_API_KEY: Authorization Bearer token for the openai-compatible provider.
# Required by the Worker when LLM_PROVIDER=openai-compatible. Never used by the API.
# WARNING: Treat as a secret — never commit, log, or expose in error messages.
# LLM_API_KEY=sk-...

# LLM_MODEL: model identifier sent in each request (default "gpt-4o-mini").
# LLM_MODEL=gpt-4o-mini

# LLM_TIMEOUT: total HTTP round-trip timeout for LLM requests (default 60s).
# LLM_TIMEOUT=60s

# LLM_TEMPERATURE: sampling temperature 0–2 (default 0.0 for deterministic output).
# LLM_TEMPERATURE=0.0

# LLM_MAX_TOKENS: maximum tokens in the LLM response (default 512).
# LLM_MAX_TOKENS=512

# LLM_MAX_RESP_BYTES: response body size limit in bytes (default 524288 = 512 KiB).
# LLM_MAX_RESP_BYTES=524288

# LLM_MAX_SCHEMA_BYTES: max serialized schema size passed in the prompt (default 16384 = 16 KiB).
# LLM_MAX_SCHEMA_BYTES=16384

# LLM_ALLOW_LOCAL_HTTP: allow plain HTTP only when ALL resolved IPs are loopback.
# The Worker pins actual dials to those validated IPs to prevent DNS rebinding.
# MUST be false in production. Set true only for local dev with a loopback proxy.
# LLM_ALLOW_LOCAL_HTTP=false

# The Worker reads only parameterized metadata for products, orders, and
# order_items (column name/type/nullability/primary key), bounded by
# LLM_MAX_SCHEMA_BYTES. LLM output must be one JSON object containing only sql;
# SQL Guard remains mandatory before execution. API, migrations, and fake mode
# never require LLM_API_KEY. No LLM setting is stored in a migration.
